{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Базовые права окон (main + мини-плеер). Tauri v2: default-deny, каждый плагин добавляет своё разрешение сюда явно.",
  "windows": ["main", "mini"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    "autostart:default",
    "updater:default",
    "process:allow-restart",
    "drag:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://**" }]
    }
  ]
}
