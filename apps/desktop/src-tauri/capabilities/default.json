{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Базовые права главного окна. Tauri v2: default-deny, каждый плагин добавляет своё разрешение сюда явно.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "autostart:default",
    "updater:default",
    "process:allow-restart",
    "drag:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://**" }]
    }
  ]
}
